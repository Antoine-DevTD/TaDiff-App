NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Legal identity displayed on the public legal pages.
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_LEGAL_FORM=
NEXT_PUBLIC_LEGAL_ADDRESS=
NEXT_PUBLIC_LEGAL_REGISTRATION=
NEXT_PUBLIC_LEGAL_VAT=
NEXT_PUBLIC_LEGAL_DIRECTOR=
NEXT_PUBLIC_PRIVACY_EMAIL=contact@tadiff.com
NEXT_PUBLIC_SUPPORT_EMAIL=contact@tadiff.com
NEXT_PUBLIC_BILLING_EMAIL=contact@tadiff.com
NEXT_PUBLIC_BETA_PRICE=19,99 EUR TTC par mois
NEXT_PUBLIC_LEGAL_VERSION=1.0

# Optional integrations. Leave empty to keep preview mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BETA_MONTHLY=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_STUDIO_MONTHLY=
RESEND_API_KEY=

# Stockage prive. Supabase reste le fournisseur par defaut. Pour R2, configurer
# aussi une regle CORS autorisant PUT depuis le domaine TaDiff.
STORAGE_PROVIDER=supabase
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DOCUMENTS_BUCKET=

# William IA - secrets serveur uniquement
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
STRIPE_PRICE_AI_100K=
STRIPE_PRICE_AI_500K=
STRIPE_PRICE_AI_2M=

# Optional maintenance gate. Leave disabled in normal production.
TADIFF_MAINTENANCE_MODE=false
TADIFF_MAINTENANCE_ALLOWED_IPS=
TADIFF_MAINTENANCE_BYPASS_TOKEN=
